<!-- Home SOC Lab v2.0 — Custom Detection Rules -->
<!-- Location: /var/ossec/etc/rules/local_rules.xml -->
<!-- Wazuh Version: 4.14.4 -->
<!-- Author: Ahmed Salam -->
<!-- Note: Wazuh 4.14.4 uses sysmon_eid*_detections group naming -->
<!--       (not the older sysmon_event* format) -->

<group name="custom_soc_lab,">

  <!-- Rule 100001 — PowerShell Encoded Command Execution -->
  <!-- MITRE ATT&CK: T1059.001 — Command and Scripting Interpreter: PowerShell -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100001" level="10">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\-[Ee][Nn][Cc][Oo][Dd][Ee][Dd][Cc][Oo][Mm][Mm][Aa][Nn][Dd]</field>
    <description>PowerShell encoded command execution detected (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>attack,powershell,execution,</group>
  </rule>

  <!-- Rule 100002 — Office Application Spawns PowerShell -->
  <!-- MITRE ATT&CK: T1059.001 — Command and Scripting Interpreter: PowerShell -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100002" level="13">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(WINWORD|EXCEL|POWERPNT|OUTLOOK)\.EXE</field>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe</field>
    <description>CRITICAL: Office application spawned PowerShell — possible macro execution (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>attack,powershell,execution,macro,critical,</group>
  </rule>

  <!-- Rule 100003 — LSASS Memory Access (Credential Dumping) -->
  <!-- MITRE ATT&CK: T1003.001 — OS Credential Dumping: LSASS Memory -->
  <!-- Sysmon Event ID 10 — Process Access -->
  <rule id="100003" level="14">
    <if_group>sysmon_eid10_detections</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe</field>
    <description>CRITICAL: LSASS memory access detected — credential dumping attempt (T1003.001)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>attack,credential_dumping,lsass,critical,</group>
  </rule>

  <!-- Rule 100004 — Registry Run Key Persistence -->
  <!-- MITRE ATT&CK: T1547.001 — Boot or Logon Autostart Execution: Registry Run Keys -->
  <!-- Sysmon Event ID 13 — Registry Value Set -->
  <rule id="100004" level="10">
    <if_group>sysmon_eid13_detections</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\(Run|RunOnce)\\</field>
    <description>Registry Run key modification detected — possible persistence (T1547.001)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
    <group>attack,persistence,registry,</group>
  </rule>

  <!-- Rule 100005 — New Local User Account Created -->
  <!-- MITRE ATT&CK: T1136.001 — Create Account: Local Account -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100005" level="10">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)net\s+(user\s+\S+\s+\S+\s+\/add|localgroup\s+administrators\s+\S+\s+\/add)</field>
    <description>New local user account created via net command (T1136.001)</description>
    <mitre>
      <id>T1136.001</id>
    </mitre>
    <group>attack,account_creation,persistence,</group>
  </rule>

  <!-- Rule 100006 — Windows Event Log Cleared -->
  <!-- MITRE ATT&CK: T1070.001 — Indicator Removal: Clear Windows Event Logs -->
  <!-- Chains off Wazuh built-in rule 60106 -->
  <rule id="100006" level="14">
    <if_sid>60106</if_sid>
    <description>CRITICAL: Windows event log cleared — anti-forensics activity (T1070.001)</description>
    <mitre>
      <id>T1070.001</id>
    </mitre>
    <group>attack,defense_evasion,log_clearing,critical,</group>
  </rule>

  <!-- Rule 100007 — Process Injection Indicators -->
  <!-- MITRE ATT&CK: T1055 — Process Injection -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100007" level="12">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(VirtualAllocEx|WriteProcessMemory|CreateRemoteThread|NtCreateThreadEx)</field>
    <description>Process injection API calls detected in command line (T1055)</description>
    <mitre>
      <id>T1055</id>
    </mitre>
    <group>attack,process_injection,defense_evasion,</group>
  </rule>

  <!-- Rule 100008 — Executable Dropped in Temp Folder -->
  <!-- MITRE ATT&CK: T1105 — Ingress Tool Transfer -->
  <!-- Sysmon Event ID 11 — File Created -->
  <rule id="100008" level="10">
    <if_group>sysmon_eid11_detections</if_group>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(Temp|tmp)\\.*\.(exe|dll|bat|ps1|vbs|cmd)</field>
    <description>Executable file dropped in Temp folder — possible tool transfer (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>attack,ingress_tool_transfer,</group>
  </rule>

  <!-- Rule 100009 — RDP Lateral Movement -->
  <!-- MITRE ATT&CK: T1021.001 — Remote Services: Remote Desktop Protocol -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100009" level="8">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)mstsc\.exe</field>
    <description>RDP client launched — possible lateral movement (T1021.001)</description>
    <mitre>
      <id>T1021.001</id>
    </mitre>
    <group>attack,lateral_movement,rdp,</group>
  </rule>

  <!-- Rule 100010 — Suspicious Directory Enumeration -->
  <!-- MITRE ATT&CK: T1083 — File and Directory Discovery -->
  <!-- Sysmon Event ID 1 — Process Creation -->
  <rule id="100010" level="7">
    <if_group>sysmon_eid1_detections</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(dir\s+.*\/[sS]|tree\s+.*\/[fF]|Get-ChildItem\s+.*-Recurse)</field>
    <description>Suspicious directory enumeration detected (T1083)</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>attack,discovery,file_discovery,</group>
  </rule>

</group>
